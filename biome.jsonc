{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core", "ultracite/biome/react"],
  "root": true,
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "!src/routeTree.gen.ts",
      "!src/components/ui",
      "!src/components/ai-elements",
      "!src/routes/conversation.$id.tsx",
      "!src/routes/index.tsx",
      "!src/hooks/use-event-stream.ts",
      "!src/hooks/use-streaming-message.ts",
      "!src/utils/async-queue.ts",
      "!.worktrees",
      "!.claude/worktrees"
    ]
  },
  "javascript": {
    "globals": ["MAIN_WINDOW_VITE_DEV_SERVER_URL", "MAIN_WINDOW_VITE_NAME"]
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
